# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
vendor/

# Local environment
.env
.env.*
!.env.example

# Dev-only secrets bootstrap directory (generated by `make dev-secrets`)
.secrets/

# OS cruft
.DS_Store
Thumbs.db

# Editor / IDE
.vscode/
.idea/
*.swp

# Build outputs
bin/
dist/

# Root-level Go build artefacts (produced by `go build ./cmd/<name>` without -o)
/writer
/deliverer
/funcoptslint

# Coverage
coverage.out
coverage.html
