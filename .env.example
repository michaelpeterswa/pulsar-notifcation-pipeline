# Copy this file to `.env` and edit to override defaults for the local stack.
# `docker compose` picks it up automatically; the file is gitignored.
#
# All variables are optional — docker-compose.yml supplies sensible defaults.

# --- Shared ----------------------------------------------------------------

# debug | info | warn | error
LOG_LEVEL=info

# Enable OpenTelemetry tracing export to the local Grafana LGTM stack.
TRACING_ENABLED=false

# --- Deliverer -------------------------------------------------------------

# Which push provider the deliverer instantiates:
#   sandbox  — in-memory (no external delivery; safe default for local dev)
#   pushover — real Pushover API (requires PUSHOVER_APP_TOKEN below)
PROVIDER=sandbox

# Pushover application API token. Required only when PROVIDER=pushover.
# See https://pushover.net/apps/build
PUSHOVER_APP_TOKEN=

# Override the Pushover API base URL (useful to point at an httptest mock or a
# staging endpoint). Empty uses the real https://api.pushover.net.
PUSHOVER_BASE_URL=

# --- Demo recipe (`just demo`) --------------------------------------------

# Default Pushover user/group key for `just demo`. Must be YOUR key — the
# Pushover docs example key (uQiRzpo4DXghDmr9QzzfQu27cmVRsG) is not a real
# recipient and will be rejected by Pushover with provider-rejected-recipient.
PUSHOVER_USER_KEY=
